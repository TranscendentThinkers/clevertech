 {
  "align": "Left",
  "content": "<table class=\"no-border\" style=\"width:100%; border-collapse:collapse; margin-top:0px;\"> \n<tbody><tr> \n\n<td style=\"text-align:left; vertical-align:top; width:45%; padding-right:0px;\">\n    <img src=\"https://clevertech-uat.bharatbodh.com/files/376e40c1-6682-408c-bf57-0cade8c2e8de.png\" alt=\"Clevertech\" style=\"height:85px; width:auto; margin-top:-15px;margin-left:-15px;\">\n</td>\n<!-- RIGHT SIDE TEXT -->\n<td style=\"text-align:right; vertical-align:top; color:#1f2937; font-size:11px; width:65%; padding-left:20px;\">\n    \n   <strong style=\"font-size:11px;\">\n            CLEVERTECH PACKAGING AUTOMATION SOLUTIONS PVT. LTD.\n        </strong>\n     <br> Plot No PAP G-3, Village Sawardari,<br>\n     Chakan MIDC Phase 2,<br>\n     Chakan Industrial Area Phase 2-410501,<br>\n     Maharashtra, India </td> </tr>\n     </tbody></table> <!-- GREY LINE -->\n     <div style=\"border-top:1px solid #cfcfcf; margin-top:5px;\"></div>",
  "disabled": 0,
  "docstatus": 0,
  "doctype": "Letter Head",
  "footer": "<!-- PARTICIPANT SECTION -->\n<table style=\"width:100%; border-collapse:collapse; margin-top:0px;\">\n<tbody><tr>\n\n<!-- LEFT COMPANY -->\n<td style=\"width:50%; vertical-align:top; padding-right:10px;\">\n\n    {% if doc.inspected_by %}\n        {% set user_doc = frappe.get_doc(\"User\", doc.inspected_by) %}\n        {% set emp_name = frappe.db.get_value(\"Employee\",\n            {\"user_id\": doc.inspected_by},\n            \"name\") %}\n        {% if emp_name %}\n            {% set emp_doc = frappe.get_doc(\"Employee\", emp_name) %}\n        {% endif %}\n    {% endif %}\n\n    <table style=\"width:100%; border-collapse:collapse;\">\n\n        <tbody><tr>\n            <td colspan=\"4\" style=\"text-align:center; font-weight:bold;\">\n                FOR<br>\n                CLEVERTECH PACKAGING AUTOMATION SOLUTIONS PVT. LTD.\n            </td>\n        </tr>\n\n        <tr>\n            <th style=\"width:10%;\">SR.NO</th>\n            <th style=\"width:40%;\">NAME</th>\n            <th style=\"width:25%;\">DESIGNATION</th>\n            <th style=\"width:25%;\">SIGN</th>\n        </tr>\n\n        <tr>\n            <td>01</td>\n            <td>{{ user_doc.full_name if user_doc }}</td>\n            <td>{{ emp_doc.designation if emp_doc }}</td>\n            <td></td>\n        </tr>\n\n        <tr>\n            <td>02</td>\n            <td></td>\n            <td></td>\n            <td></td>\n        </tr>\n\n        <tr>\n            <td>03</td>\n            <td></td>\n            <td></td>\n            <td></td>\n        </tr>\n\n    </tbody></table>\n\n</td>\n\n<!-- RIGHT SUPPLIER -->\n<td style=\"width:50%; vertical-align:top; padding-left:10px;\">\n\n    <table style=\"width:100%; border-collapse:collapse;\">\n\n        <tbody><tr>\n            <td colspan=\"4\" style=\"text-align:center; font-weight:bold;\">\n                FOR<br>\n                {{ frappe.db.get_value(\"Supplier\", doc.supplier, \"supplier_name\") }}\n            </td>\n        </tr>\n\n        <tr>\n            <th style=\"width:10%;\">SR.NO</th>\n            <th style=\"width:40%;\">NAME</th>\n            <th style=\"width:25%;\">DESIGNATION</th>\n            <th style=\"width:25%;\">SIGN</th>\n        </tr>\n\n        <tr>\n            <td>01</td>\n            <td></td>\n            <td></td>\n            <td></td>\n        </tr>\n\n        <tr>\n            <td>02</td>\n            <td></td>\n            <td></td>\n            <td></td>\n        </tr>\n         <tr>\n            <td>03</td>\n            <td></td>\n            <td></td>\n            <td></td>\n        </tr>\n\n\n\n\n\n    </tbody></table>\n\n</td>\n\n</tr>\n</tbody></table>\n\n{% set session_user = frappe.session.user %}\n\n{% set emp_name = frappe.db.get_value(\"Employee\",\n    {\"user_id\": session_user},\n    \"name\") %}\n\n{% if emp_name %}\n    {% set leave_approver_user = frappe.db.get_value(\"Employee\",\n        emp_name,\n        \"leave_approver\") %}\n{% endif %}\n\n{% if leave_approver_user %}\n    {% set approver_fullname = frappe.db.get_value(\"User\",\n        leave_approver_user,\n        \"full_name\") %}\n{% endif %}\n\n<div style=\"width:100%; margin-top:10px; overflow:hidden;\">\n\n    <div style=\"width:50%; float:left; text-align:left;\">\n        <strong>INSPECTED BY:-</strong>\n        {{ frappe.db.get_value(\"User\", session_user, \"full_name\") }}\n    </div>\n\n    <div style=\"width:50%; float:right; text-align:right;\">\n        <strong>APPROVED BY:-</strong>\n        {{ approver_fullname if approver_fullname }}\n    </div>\n\n</div>\n\n<div style=\"clear:both;\"></div>\n",
