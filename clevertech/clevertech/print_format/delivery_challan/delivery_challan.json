 "html": "<html lang=\"en\">\r\n    <p style=\"margin-top: 0; margin-bottom: 0;\"><font face=\"Calibri\" style=\"font-size: 9pt;\">{%- macro add_header(page_num, max_pages, doc, letter_head, no_letterhead) -%} {% if letter_head and not no_letterhead %}</font></p>\r\n\t<div style=\"height:17mm;\" class=\"letter-head\">\r\n\t  <p style=\"margin-top: 0; margin-bottom: 0;\"><font face=\"Calibri\" style=\"font-size: 9pt;\">{{ letter_head }}</font></p>\r\n\t</div>\r\n\t<p style=\"margin-top: 0; margin-bottom: 0;\"><font face=\"Calibri\" style=\"font-size: 9pt;\">{% endif %} {% if max_pages > 1 %}</font></p>\r\n\t<p class=\"text-right\" style=\"margin-top: 0; margin-bottom: 0;\"><font face=\"Calibri\" style=\"font-size: 9pt;\">{{ _(\"Page #{0} of {1}\").format(page_num, max_pages) }}</font></p>\r\n\t<p style=\"margin-top: 0; margin-bottom: 0;\"><font face=\"Calibri\" style=\"font-size: 9pt;\">{% endif %} {%- endmacro -%}</font></p>\r\n\t<div id=\"header-html\" class=\"hidden-pdf\">\r\n\t  <p style=\"margin-top: 0; margin-bottom: 0;\"><small><big><font face=\"Calibri\" style=\"font-size: 9pt;\">{{ add_header(0,1,doc,letter_head, no_letterhead) }}</font></big></small></p>\r\n\t\t<p style=\"margin-top: 0; margin-bottom: 0;\">\r\n\t\t</p>\r\n\t</div>\r\n\t<div id=\"footer-html\" class=\"visible-pdf\">\r\n\t\t\t<p style=\"margin-top: 0; margin-bottom: 15px\">\r\n\t\t\t<font face=\"Calibri\" style=\"font-size: 8pt\">{% if not no_letterhead and footer %}\r\n\t\t\t</font>\r\n\t\t\t</p>\r\n\t\t\t<div  style=\"height: -5px;\" class=\"letter-head-footer\">\r\n\t\t\t\t<p style=\"margin-top: 5px; margin-bottom: 0\">\r\n\t\t\t\t<font face=\"Calibri\" style=\"font-size: 8pt\">{{ footer }}\r\n\t\t\t</font>\r\n\t\t\t</div>\r\n\t\t\t<p style=\"margin-top: 0; margin-bottom: 0\">\r\n\t\t\t<font face=\"Calibri\" style=\"font-size: 8pt\">{% endif %}\r\n\t\t\t</font>\r\n\t\t\t</p>\r\n\t\t\t<p class=\"text-center small page-number visible-pdf\" style=\"margin-top: 0; margin-bottom: 0\" align=\"right\">\r\n\t\t\r\n\t\t\t<p class=\"text-center small page-number visible-pdf\" style=\"margin-top: 0; margin-bottom: 0\" align=\"center\">\r\n\t\t\t\t<font face=\"Calibri\" style=\"font-size: 8pt\">{{ _(\"Page {0} of {1}\").format('</font><span class=\"page\"></span><font face=\"Calibri\" style=\"font-size: 8pt\">', '</font><span class=\"topage\"></span><font face=\"Calibri\" style=\"font-size: 8pt\">') }}</font></p>\r\n\t\t</div>\r\n\r\n\r\n\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n   \r\n    <style>\r\n    #footer-html {\r\n        display: none;\r\n    }\r\n\r\n    /* Display the footer only on the last page */\r\n    @media print {\r\n        @page :last {\r\n            #footer-html {\r\n                display: block;\r\n                margin-top: 10mm; /* Add space before the footer */\r\n            }\r\n        }\r\n    }\r\n   \r\n        body {\r\n            font-family: Arial, sans-serif;\r\n            margin: 5px;\r\n        }\r\n\r\n        .header {\r\n            text-align: center;\r\n            font-size: 24px;\r\n            color: black;\r\n            margin-bottom: 20px;\r\n            background-color: lightpink;\r\n        }\r\n\r\n        .details {\r\n            font-size: 14px;\r\n            margin-bottom: 10px;\r\n            \r\n        }\r\n\r\n\r\n        table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 0px;\r\n            margin-bottom: 0px;\r\n             font-size: 10px;\r\n        }\r\n\r\n        table,\r\n        th,\r\n        td {\r\n            border: 1px solid black;\r\n           \r\n        }\r\n\r\n        th,\r\n        td {\r\n            padding: 8px;\r\n            text-align: center;\r\n            \r\n        }\r\n\r\n        .no-border {\r\n            border: none;\r\n        }\r\n        .page-break {\r\n            page-break-before: always;\r\n        }\r\n        .footer-section {\r\n            position: fixed;\r\n            bottom: 0;\r\n            width: 100%;\r\n            font-size: 12px;\r\n        }\r\n        .content {\r\n            padding-bottom: 200px; /* Ensure enough space for footer */\r\n        }\r\n          @media print {\r\n            /* Footer displayed only on the last page */\r\n            @page :last {\r\n                #footer-html {\r\n                    display: block;\r\n                    margin-top: 10mm;\r\n                }\r\n            }\r\n    .footer-section {\r\n        position: fixed;\r\n        bottom: 0;\r\n        width: 100%;\r\n        font-size: 12px;\r\n        display: block; /* Ensure it's visible */\r\n        page-break-inside: avoid; /* Prevent content from breaking inside */\r\n    }\r\n\r\n    #footer-html {\r\n        display: block; /* Ensure the footer is visible in print */\r\n        margin-top: 10mm;\r\n    }\r\n}\r\n        \r\n        \r\n        \r\n\r\n     \r\n    </style>\r\n    </head>\r\n    <div class=\"row\" style=\"display: flex; justify-content: center; align-items: center; margin: 0; padding: 0; position: relative;\">\r\n    <div class=\"col-xs-12\" style=\"text-align: left; padding: 0; margin: 0; flex: 1;\">\r\n        <h2 style=\"margin-top: 0px;  text-align:center;\">\r\n            <strong>Delivery Challan</strong>\r\n        </h2>\r\n    </div>\r\n    \r\n</div>\r\n     <div class=\"details\">\r\n    <div class=\"row\" style=\"margin: 0; padding: 0;\">\r\n        <div class=\"col-xs-6\" style=\"padding: 0; margin-top: -6px;;\">\r\n            <!-- Shipping Address -->\r\n            <p style=\"margin: 10px 0 0 0; font-size: 11px;\"> <!-- Adjust the font size as needed -->\r\n<!--<strong> Date:</strong>{{ doc.posting_date }}<br>-->\r\n                            <strong> Delivery To: </strong><br>\r\n                             <strong>Party Name: </strong> {{doc.customer}}<br>\r\n                \r\n                  <strong> Delivery Address: </strong>{{doc.address_display}}\r\n                 \r\n                  \r\n                <p style=\"margin: 0px;font-size: 11px;\">\r\n              <strong>Kind Attn.: </strong>{{ doc.custom_kind_attn_of or \"\"}}<br>\r\n              <strong>Phone: </strong>{{ doc.custom_contact_no or \"\"}}<br>\r\n               </p>\r\n            </p>\r\n        </div>\r\n        <div class=\"col-xs-6\" style=\"padding: 0; margin: 0;\">\r\n            <p style=\"margin: 0 0 0 130px; font-size: 11px;\"> <!-- Adjust the font size as needed -->\r\n                \r\n                <strong>Purpose of Delivery: </strong>{{doc.custom_purpose_of_delivery or \"\"}}<br>\r\n                <strong>Delivery Challan No.:  </strong>{{ doc.name }}<br>\r\n                <strong>Document Date:  </strong>{{frappe.utils.get_datetime(doc.po_date).strftime(\"%d-%m-%Y\")}}<br>\r\n                <strong>Project No:  </strong>{{doc.project}}\r\n                \r\n            </p>\r\n        </div>\r\n    </div>\r\n</div>\r\n     \r\n<body>\r\n    \r\n   <!-- Items Table Section -->\r\n<table style=\"margin: 10px 0 0 0; border-collapse: collapse; width: 100%; font-size: 10px;\" >\r\n    <thead>\r\n        <tr>\r\n<strong><th style=\"width: 5%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Sr No.</th></strong>\r\n<strong><th style=\"width: 5%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Material Code</th></strong>\r\n<strong><th style=\"width: 75%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Material Description</th></strong>\r\n<strong><th style=\"width:5%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">HSN</th></strong>\r\n<strong><th style=\"width: 5%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Quantity</th></strong>\r\n<strong><th style=\"width: 5%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">UOM</th></strong>\r\n<strong><th style=\"width: 70%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Unit Rate </th></strong>\r\n<strong><th style=\"width: 70%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Amount</th></strong>\r\n<strong><th style=\"width: 85%; font-size: 12px;color: black; font-weight: bold;font-size: 9px;\">Remark</th></strong>\r\n        </tr>\r\n    </thead>\r\n    <tbody>\r\n       {% for row in doc.items %}\r\n            <tr>\r\n                <td style=\"font-size: 11px;\">{{ loop.index }}</td>\r\n                 <td style=\"font-size: 11px; padding: 2px; border: 1px solid black; text-align: left;\">{{row.item_code}}</td>\r\n                 \r\n                <td style=\"font-size: 11px; padding: 2px; border: 1px solid black; text-align: left;\">{{ row.item_name }}</td>\r\n                <td  style=\"font-size: 11px;\">{{ row.gst_hsn_code }}</td>\r\n\r\n                <td  style=\"font-size: 11px;\">{{ row.qty }}</td>\r\n                <td  style=\"font-size: 11px;\">{{row.uom}}</td>\r\n                <td  style=\"font-size: 11px;\">{{row.rate}}\r\n                   </td>\r\n                <td  style=\"font-size: 11px;\">{{row.amount}}</td>\r\n               <td style=\"font-size: 12px;\">\r\n      {% if row.custom_remark %}\r\n        {{ row.custom_remark }}\r\n      {% else %}\r\n        \r\n      {% endif %}\r\n    </td>\r\n    </tr>\r\n            {% endfor %}\r\n            <tr>\r\n      <td style=\"padding:2px 2px 2px 2px ;\"></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;text-align: left;\"><b>Total</b></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\"></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\"></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\">{{ doc.total_qty }}</td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\"></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\"></td>\r\n      <td style=\"padding:2px 2px 2px 2px ;\">{{ doc.base_total }}</td>\r\n     \r\n\r\n      <td style=\"padding:2px 2px 2px 2px !important;border: 1px solid #000;\"></td>\r\n\r\n  </tr>\r\n             </tbody>\r\n</table>\r\n \r\n    </div>\r\n    \r\n  </div>\r\n  \r\n  {% if doc.instructions %}\r\n  <p style=\"margin:4px;font-size: 11px;margin-left:-2px;\">\r\n    <b>&nbsp;Remark: </b>{{ doc.instructions }}\r\n  </p>\r\n{% else %}\r\n  <p style=\"margin:4px;font-size: 11px;margin-left:-2px;\">\r\n    <b>&nbsp;Remark: </b>\r\n  </p>\r\n{% endif %}\r\n\r\n<br><br>\r\n\r\n{% if doc.terms %}\r\n  <p style=\"margin: 0px;font-size: 11px;\">\r\n    <b >Terms: </b>\r\n    <p style=\"margin: 0px;font-size:5px;\">{{ doc.terms }}</p>\r\n  </p>\r\n{% else %}\r\n  <p style=\"margin: 0px;font-size: 11px;\">\r\n    <b>Terms: </b>\r\n  </p>\r\n{% endif %}\r\n\r\n \r\n \r\n     \r\n            <table style=\"width: 30%; float:right;\" class=\"no-border\">\r\n  <tr style=\"text-align:left;\">\r\n    <td style=\"text-align:left;\"><b>Authorized Signatory</b><br><br><br><br>\r\n    <b>Prepared by: </b><br>\r\n    <b>Designation: </b>\r\n    </td>\r\n  </tr>\r\n\r\n</table>\r\n\r\n   \r\n\r\n\r\n    \r\n    \r\n</body>\r\n\r\n\r\n</html>\r\n",
